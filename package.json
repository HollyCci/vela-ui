  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HollyCci/vela-ui.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.lib.ts && tsc -p tsconfig.build.json",
    "build:demo": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:exports": "node scripts/generate-exports.cjs",
    "check:exports": "node scripts/generate-exports.cjs --check",
    "generate:css-index": "node scripts/generate-css-index.cjs",
    "check:css-index": "node scripts/generate-css-index.cjs --check",
    "generate:pro-checklist": "node scripts/generate-pro-parity-checklist.cjs",
    "check:pro-checklist": "node scripts/generate-pro-parity-checklist.cjs --check",
    "smoke": "node scripts/smoke-publish.cjs",
    "prepublishOnly": "npm run build && npm run smoke",
    "audit:css:parity": "node scripts/css-parity-check.cjs",
    "audit:fingerprint": "node scripts/audit-fingerprint.cjs",
    "audit:all": "npm run audit:pro && npm run check:exports && npm run check:css-index && npm run check:pro-checklist && npm run audit:css:parity && npm run audit:fingerprint",
    "audit:goal": "npm run audit:all && npm run audit:pro:browser",
    "audit:pro": "node scripts/audit-pro-coverage.cjs && node scripts/audit-pro-interactivity.cjs && node scripts/audit-pro-parity.cjs",
    "audit:pro:browser": "node scripts/audit-pro-browser-smoke.cjs",
    "audit:pro:coverage": "node scripts/audit-pro-coverage.cjs",
    "audit:pro:interactivity": "node scripts/audit-pro-interactivity.cjs",
    "audit:pro:parity": "node scripts/audit-pro-parity.cjs"
  },
  "peerDependencies": {
    "@heroui/react": "^3.2.0",
