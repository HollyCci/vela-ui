{
  "name": "vela-ui",
  "version": "0.1.0",
  "type": "module",
  "license": "UNLICENSED",
  "description": "Vela UI — 基于 HeroUI + React Aria Components 的企业级组件库",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.lib.ts && tsc -p tsconfig.build.json",
    "build:demo": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "prepublishOnly": "npm run build",
    "audit:pro": "node scripts/audit-pro-coverage.cjs && node scripts/audit-pro-interactivity.cjs",
    "audit:pro:coverage": "node scripts/audit-pro-coverage.cjs",
    "audit:pro:interactivity": "node scripts/audit-pro-interactivity.cjs"
  },
  "peerDependencies": {
    "@heroui/react": "^3.1.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-aria-components": "1.17.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@heroui/react": { "optional": false },
    "react-aria-components": { "optional": false }
  },
  "dependencies": {
    "@number-flow/react": "^0.6.0",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "motion": "^12.40.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@heroui-pro/react": "1.0.0-beta.5",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.2.7",
    "react-aria-components": "1.17.0",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
