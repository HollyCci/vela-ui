false\" href=\"#css-classes\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-3\">CSS Classes</a><a data-active=\"false\" href=\"#base--size-classes\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">Base &amp; Size Classes</a><a data-active=\"false\" href=\"#element-classes\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">Element Classes</a><a data-active=\"false\" href=\"#interactive-states\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">Interactive States</a><a data-active=\"false\" href=\"#api-reference\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-3\">API Reference</a><a data-active=\"false\" href=\"#numberstepper\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">NumberStepper</a><a data-active=\"false\" href=\"#numbersteppergroup\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">NumberStepper.Group</a><a data-active=\"false\" href=\"#numbersteppervalue\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">NumberStepper.Value</a><a data-active=\"false\" href=\"#numberstepperdecrementbutton\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">NumberStepper.DecrementButton</a><a data-active=\"false\" href=\"#numberstepperincrementbutton\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-6\">NumberStepper.IncrementButton</a>"}