p.Value</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\"> /&gt;</span></span>\n<span class=\"line\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">  &lt;/</span><span style=\"--shiki-light:#005CC5;--shiki-dark:#79B8FF\">ChartTooltip.Item</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">&gt;</span></span>\n<span class=\"line\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">&lt;/</span><span style=\"--shiki-light:#005CC5;--shiki-dark:#79B8FF\">ChartTooltip</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">&gt;</span></span></code></pre></div></figure>\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"auto-content\"><a data-card=\"\" href=\"#auto-content\" class=\"peer\">Auto Content</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n"}, {"type": "demo", "slug": "chart-tooltip-auto-content"}, {"type": "html", "html": "\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"chart-colors\"><a data-card=\"\" href=\"#chart-colors\" class=\"peer\">Chart Colors</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n"}, {"type": "demo", "slug": "chart-tooltip-chart-colors"}, {"type": "html", "html": "\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"custom-formatters\"><a data-card=\"\" href=\"#custom-formatters\" class=\"peer\">Custom Formatters</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n"}, {"type": "demo", "slug": "chart-tooltip-custom-formatters"}, {"type": "html", "html": "\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"inactive\"><a data-card=\"\" href=\"#inactive\" class=\"peer\">Inactive</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n"}, {"type": "demo", "slug": "chart-tooltip-inactive"}, {"type": "html", "html": "\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"line-indicator\"><a data-card=\"\" href=\"#line-indicator\" class=\"peer\">Line Indicator</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n"}, {"type": "demo", "slug": "chart-tooltip-line-indicator"}, {"type": "html", "html": "\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"no-header\"><a data-card=\"\" href=\"#no-header\" class=\"peer\">No Header</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n"}, {"type": "demo", "slug": "chart-tooltip-no-header"}, {"type": "html", "html": "\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"css-classes\"><a data-card=\"\" href=\"#css-classes\" class=\"peer\">CSS Classes</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"element-classes\"><a data-card=\"\" href=\"#element-classes\" class=\"peer\">Element Classes</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<ul>\n<li><code>.chart-tooltip</code> — Root tooltip card container. Rounded border with surface background and overlay shadow.</li>\n<li><code>.chart-tooltip__header</code> — Optional title row (e.g., the X-axis label). Muted 12px medium text.</li>\n<li><code>.chart-tooltip__item</code> — A single series entry row. Flex layout with gap.</li>\n<li><code>.chart-tooltip__indicator</code> — Color marker next to the series name.</li>\n<li><code>.chart-tooltip__indicator--dot</code> — Dot-shaped indicator. Small circle (8px).</li>\n<li><code>.chart-tooltip__indicator--line</code> — Line-shaped indicator. Tall narrow pill (12px × 4px).</li>\n<li><code>.chart-tooltip__label</code> — Series name text. Muted 12px, fills available space.</li>\n<li><code>.chart-tooltip__value</code> — Series data value. Semibold 12px foreground text.</li>\n</ul>\n<h2 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"api-reference\"><a data-card=\"\" href=\"#api-reference\" class=\"peer\">API Reference</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h2>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltip\"><a data-card=\"\" href=\"#charttooltip\" class=\"peer\">ChartTooltip</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>The root tooltip container. Controls visibility and indicator style via context.</p>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>active</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Controls visibility. When <code>false</code>, the tooltip is not rendered.</td></tr><tr><td><code>indicator</code></td><td><code>\"dot\" | \"line\"</code></td><td><code>\"dot\"</code></td><td>Shape of the color indicator next to each series name.</td></tr><tr><td><code>children</code></td><td><code>ReactNode</code></td><td>—</td><td>Tooltip content — typically <code>Header</code>, <code>Item</code>, <code>Indicator</code>, <code>Label</code>, and <code>Value</code> sub-components.</td></tr></tbody></table></div>\n<p>Also supports all native <code>div</code> HTML attributes.</p>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltipcontent\"><a data-card=\"\" href=\"#charttooltipcontent\" class=\"peer\">ChartTooltip.Content</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>Auto-renders a tooltip from Recharts payload data. Pass as the <code>content</code> prop of a Recharts <code>&lt;Tooltip&gt;</code>:</p>\n<figure dir=\"ltr\" class=\"my-4 bg-fd-card rounded-xl shiki relative border shadow-sm not-prose overflow-hidden text-sm mdx-code-block shiki shiki-themes github-light github-dark\" style=\"--shiki-light:#24292e;--shiki-dark:#e1e4e8;--shiki-light-bg:#fff;--shiki-dark-bg:#24292e\" tabindex=\"-1\"><div class=\"z-1! empty:hidden absolute top-3 right-2 z-2 backdrop-blur-lg rounded-lg text-fd-muted-foreground\"><button aria-label=\"Copy Text\" type=\"button\" class=\"button button--icon-only button--sm button--ghost text-muted -mt-0.5 bg-transparent\"><svg aria-hidden=\"true\" height=\"1em\" role=\"img\" viewBox=\"0 0 16 16\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\"><path fill=\"currentColor\" fill-rule=\"evenodd\" d=\"M12 2.5H8A1.5 1.5 0 0 0 6.5 4v1H8a3 3 0 0 1 3 3v1.5h1A1.5 1.5 0 0 0 13.5 8V4A1.5 1.5 0 0 0 12 2.5M11 11h1a3 3 0 0 0 3-3V4a3 3 0 0 0-3-3H8a3 3 0 0 0-3 3v1H4a3 3 0 0 0-3 3v4a3 3 0 0 0 3 3h4a3 3 0 0 0 3-3zM4 6.5h4A1.5 1.5 0 0 1 9.5 8v4A1.5 1.5 0 0 1 8 13.5H4A1.5 1.5 0 0 1 2.5 12V8A1.5 1.5 0 0 1 4 6.5\" clip-rule=\"evenodd\"></path></svg></button></div><div role=\"region\" tabindex=\"0\" class=\"text-[0.8125rem] py-3.5 overflow-auto max-h-[600px] fd-scroll-container focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-fd-ring\" style=\"--padding-right:calc(var(--spacing) * 8)\"><pre class=\"min-w-full w-max *:flex *:flex-col\"><code><span class=\"line\"><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">&lt;</span><span style=\"--shiki-light:#005CC5;--shiki-dark:#79B8FF\">Tooltip</span><span style=\"--shiki-light:#6F42C1;--shiki-dark:#B392F0\"> content</span><span style=\"--shiki-light:#D73A49;--shiki-dark:#F97583\">=</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\">{&lt;</span><span style=\"--shiki-light:#005CC5;--shiki-dark:#79B8FF\">ChartTooltip.Content</span><span style=\"--shiki-light:#24292E;--shiki-dark:#E1E4E8\"> /&gt;} /&gt;</span></span></code></pre></div></figure>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>active</code></td><td><code>boolean</code></td><td>—</td><td>Provided by Recharts — whether the tooltip is active.</td></tr><tr><td><code>label</code></td><td><code>number | string</code></td><td>—</td><td>Provided by Recharts — the X-axis label for the hovered data point.</td></tr><tr><td><code>payload</code></td><td><code>RechartsPayloadEntry[]</code></td><td>—</td><td>Provided by Recharts — array of series data for the hovered point.</td></tr><tr><td><code>hideHeader</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Hide the header row.</td></tr><tr><td><code>indicator</code></td><td><code>\"dot\" | \"line\"</code></td><td><code>\"dot\"</code></td><td>Shape of the color indicator.</td></tr><tr><td><code>labelFormatter</code></td><td><code>(label: number | string) =&gt; ReactNode</code></td><td>—</td><td>Custom formatter for the header label.</td></tr><tr><td><code>valueFormatter</code></td><td><code>(value: number | string) =&gt; ReactNode</code></td><td>—</td><td>Custom formatter for series values.</td></tr></tbody></table></div>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltipheader\"><a data-card=\"\" href=\"#charttooltipheader\" class=\"peer\">ChartTooltip.Header</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>Optional title row rendered above the series items.</p>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>children</code></td><td><code>ReactNode</code></td><td>—</td><td>Header content (typically the X-axis label text).</td></tr></tbody></table></div>\n<p>Also supports all native <code>div</code> HTML attributes.</p>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltipitem\"><a data-card=\"\" href=\"#charttooltipitem\" class=\"peer\">ChartTooltip.Item</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>A single series entry row containing an indicator, label, and value.</p>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>children</code></td><td><code>ReactNode</code></td><td>—</td><td>Row content — typically <code>Indicator</code>, <code>Label</code>, and <code>Value</code> sub-components.</td></tr></tbody></table></div>\n<p>Also supports all native <code>div</code> HTML attributes.</p>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltipindicator\"><a data-card=\"\" href=\"#charttooltipindicator\" class=\"peer\">ChartTooltip.Indicator</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>Color marker rendered next to the series name. Shape is controlled by the root <code>indicator</code> variant.</p>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>color</code></td><td><code>string</code></td><td>—</td><td>CSS color value for the indicator background.</td></tr></tbody></table></div>\n<p>Also supports all native <code>span</code> HTML attributes.</p>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltiplabel\"><a data-card=\"\" href=\"#charttooltiplabel\" class=\"peer\">ChartTooltip.Label</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>Series name text displayed between the indicator and value.</p>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>children</code></td><td><code>ReactNode</code></td><td>—</td><td>Label content (typically the series name or <code>dataKey</code>).</td></tr></tbody></table></div>\n<p>Also supports all native <code>span</code> HTML attributes.</p>\n<h3 class=\"flex scroll-m-28 flex-row items-center gap-2\" id=\"charttooltipvalue\"><a data-card=\"\" href=\"#charttooltipvalue\" class=\"peer\">ChartTooltip.Value</a><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\" aria-hidden=\"true\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></h3>\n<p>Series data value displayed at the end of each item row.</p>\n<div class=\"relative overflow-auto prose-no-margin my-6\"><table><thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody><tr><td><code>children</code></td><td><code>ReactNode</code></td><td>—</td><td>Value content (typically the formatted numeric value).</td></tr></tbody></table></div>\n<p>Also supports all native <code>span</code> HTML attributes.</p></div><div class=\"@container my-8 grid gap-4 grid-cols-2\"><a class=\"hover:text-fd-accent-foreground hover:bg-surface-secondary @max-lg:col-span-full flex flex-col gap-2 rounded-2xl p-4 text-sm transition-none\" href=\"/docs/react/components/bar-chart\"><div class=\"inline-flex items-center gap-1.5 font-medium\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"none\" viewBox=\"0 0 16 16\" class=\"-mx-1 size-4 shrink-0 rtl:rotate-180\"><path fill=\"currentColor\" fill-rule=\"evenodd\" d=\"M10.53 2.97a.75.75 0 0 1 0 1.06L6.56 8l3.97 3.97a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 0\" clip-rule=\"evenodd\"></path></svg><p>Bar Chart</p></div><p class=\"text-fd-muted-foreground truncate\">A bar chart for comparing categorical data with grouped, stacked, and horizontal layout support.</p></a><a class=\"hover:text-fd-accent-foreground hover:bg-surface-secondary @max-lg:col-span-full flex flex-col gap-2 rounded-2xl p-4 text-sm transition-none text-end\" href=\"/docs/react/components/composed-chart\"><div class=\"inline-flex items-center gap-1.5 font-medium flex-row-reverse\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"none\" viewBox=\"0 0 16 16\" class=\"-mx-1 size-4 shrink-0 rtl:rotate-180\"><path fill=\"currentColor\" fill-rule=\"evenodd\" d=\"M5.47 13.03a.75.75 0 0 1 0-1.06L9.44 8 5.47 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06 0\" clip-rule=\"evenodd\"></path></svg><p>Composed Chart</p></div><p class=\"text-fd-muted-foreground truncate\">A composed chart that combines Bar, Line, and Area series in a single cartesian chart for multi-metric dashboards.</p></a></div>"}], "tocHtml": "<a data-active=\"false\" href=\"#usage\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-3\">Usage</a><a data-active=\"false\" href=\"#anatomy\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foreground ps-3\">Anatomy</a><a data-active=\"false\" href=\"#auto-content\" class=\"prose py-1.5 text-sm text-fd-muted-foreground scroll-m-4 transition-colors wrap-anywhere first:pt-0 last:pb-0 data-[active=true]:text-fd-primary hover:text-fd-accent-foregroun