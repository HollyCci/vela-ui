{"blocks": [{"type": "html", "html": "<section class=\"flex flex-col gap-2\"><div class=\"flex flex-wrap items-center justify-between gap-2\"><h1 class=\"text-[1.75em] font-semibold flex items-center gap-2\">Chat Attachment<span class=\"chip chip--default chip--primary h-5 rounded-full bg-pink-400/8 px-1.5 text-[10px] font-semibold text-pink-400/90 w-fit\" data-slot=\"chip\"><span class=\"chip__label\" data-slot=\"chip-label\">New</span></span></h1><div class=\"flex items-center gap-2\"><div class=\"button-group button-group--horizontal\" data-slot=\"button-group\" data-rac=\"\" role=\"group\"><button data-slot=\"button\" class=\"button button--md button--tertiary\" data-rac=\"\" type=\"button\" tabindex=\"0\" data-react-aria-pressable=\"true\" id=\"react-aria-_R_cminpfsnmknb_\"><svg aria-hidden=\"true\" height=\"1em\" role=\"img\" viewBox=\"0 0 16 16\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\"><path fill=\"currentColor\" fill-rule=\"evenodd\" d=\"M12 2.5H8A1.5 1.5 0 0 0 6.5 4v1H8a3 3 0 0 1 3 3v1.5h1A1.5 1.5 0 0 0 13.5 8V4A1.5 1.5 0 0 0 12 2.5M11 11h1a3 3 0 0 0 3-3V4a3 3 0 0 0-3-3H8a3 3 0 0 0-3 3v1H4a3 3 0 0 0-3 3v4a3 3 0 0 0 3 3h4a3 3 0 0 0 3-3zM4 6.5h4A1.5 1.5 0 0 1 9.5 8v4A1.5 1.5 0 0 1 8 13.5H4A1.5 1.5 0 0 1 2.5 12V8A1.5 1.5 0 0 1 4 6.5\" clip-rule=\"evenodd\"></path></svg>Copy Markdown</button><button data-slot=\"button\" class=\"button button--icon-only button--md button--tertiary\" data-rac=\"\" type=\"button\" tabindex=\"0\" aria-haspopup=\"true\" aria-expanded=\"false\" id=\"react-aria-_R_kminpfsnmknb_\" data-react-aria-pressable=\"true\"><span aria-hidden=\"true\" class=\"button-group__separator\" data-slot=\"button-group-separator\"></span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-fd-muted-foreground size-3.5