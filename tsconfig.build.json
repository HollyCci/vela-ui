{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/index.ts", "src/components"],
  "exclude": ["src/showcase", "src/main.tsx", "**/*.test.ts", "**/*.test.tsx"]
}
